# ══════════════════════════════════════════════
#  MonoDonaty — приклад конфігурації
#  Скопіюй цей файл як .env і заповни свої дані
# ══════════════════════════════════════════════

# Monobank — особистий токен (https://api.monobank.ua/)
MONO_TOKEN=

# ID рахунку або банки Monobank (залиш порожнім для автовибору)
MONO_ACCOUNT_ID=

# Мінімальна сума доната (грн)
MONO_MIN_AMOUNT=1

# Інтервал опитування Monobank у секундах (не менше 60!)
MONO_INTERVAL=60

# Twitch — назва каналу (без #)
TWITCH_CHANNEL=

# Twitch Client ID (https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=

# Twitch OAuth токен (без "oauth:" префікса)
# Отримай на: https://twitchapps.com/tmi/
TWITCH_TOKEN=

# Шаблон повідомлення в чат (з коментарем)
TWITCH_TEMPLATE=Donat vid {name}: {amount} {currency}! {comment}

# Шаблон без коментаря
TWITCH_TEMPLATE_NO_COMMENT=Donat vid {name}: {amount} {currency}! Dyakuemo!

# TTS голос (uk-UA-OstapNeural, uk-UA-PolinaNeural тощо)
TTS_VOICE=uk-UA-OstapNeural

# Шаблон TTS
TTS_TEMPLATE=Донат від {name}, {amount} {currency}! {comment}

# Файл звукового сповіщення (відносний шлях)
SOUND_FILE=alert.mp3

# Порт сервера
PORT=8181
